  const [condition, setCondition] = useState('');
  const [results, setResults] = useState<Part[]>([]);
  const [message, setMessage] = useState('');

  async function search() {
    setMessage('');
    const res = await fetch('/api/search-parts', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ query, condition })
    });
    const data = await res.json();
    if (data.error) setMessage(data.error);
    else setResults(data.results || []);
  }

  return (
    <main className="container">
      <div className="card">
        <h1>Search aircraft parts</h1>
        <p>Paid users can search by part number, cross-reference number, or description.</p>
        <label>Search term</label>
        <input className="input" value={query} onChange={e => setQuery(e.target.value)} placeholder="Part number, cross-reference or description" />
        <label>Condition</label>
        <select value={condition} onChange={e => setCondition(e.target.value)}>
          <option value="">Any condition</option>
          <option value="new">New</option>
          <option value="used">Used</option>
          <option value="overhauled">Overhauled</option>
          <option value="serviceable">Serviceable</option>
          <option value="as_removed">As Removed</option>
          <option value="repairable">Repairable</option>
        </select>
        <button className="button" onClick={search}>Search</button>
        {message && <div className="notice error">{message}</div>}
      </div>

      {results.length > 0 && (
        <div className="card" style={{ marginTop: 20 }}>
          <h2>Results</h2>
          <table className="table">
            <thead>
              <tr><th>Part number</th><th>Cross-ref</th><th>Description</th><th>Qty</th><th>Condition</th><th>Paperwork</th></tr>
            </thead>
            <tbody>
              {results.map(part => (
                <tr key={part.id}>
                  <td>{part.part_number}</td>
                  <td>{part.cross_reference}</td>
                  <td>{part.description}</td>
                  <td>{part.quantity}</td>
                  <td>{part.condition}</td>
                  <td>{part.paperwork_status}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </main>
  );
}

'use client';

import { useEffect, useState } from 'react';
import { supabase } from '@/lib/supabaseClient';

export default function AccountPage() {
  const [profile, setProfile] = useState<any>(null);
  const [role, setRole] = useState('seller');

  useEffect(() => {
    loadProfile();
  }, []);

  async function loadProfile() {
    const { data: userData } = await supabase.auth.getUser();
    const user = userData.user;
    if (!user) return;

    const { data } = await supabase.from('profiles').select('*').eq('id', user.id).single();
    setProfile(data);
    setRole(data?.role || 'seller');
  }

  async function updateRole() {
    const { data: userData } = await supabase.auth.getUser();
    const user = userData.user;
    if (!user) return alert('Please login first.');

    const { error } = await supabase.from('profiles').upsert({
      id: user.id,
      email: user.email,
      role
    });
    if (error) alert(error.message);
    else loadProfile();
  }

  return (
    <main className="container">
      <div className="card">
        <h1>Account</h1>
        <p>Choose whether this account is a seller, a searcher, or both.</p>
        <label>Account type</label>
        <select value={role} onChange={e => setRole(e.target.value)}>
          <option value="seller">Seller</option>
          <option value="searcher">Searcher</option>
          <option value="both">Both</option>
        </select>
        <button className="button" onClick={updateRole}>Save account type</button>
        {profile && (
          <div className="notice">
            <strong>Status:</strong> {profile.subscription_status || 'inactive'}<br />
            <strong>Search credits:</strong> {profile.search_credits || 0}
          </div>
        )}
      </div>
    </main>
  );
}

'use client';

import { useState } from 'react';

export default function UploadPage() {
  const [file, setFile] = useState<File | null>(null);
  const [message, setMessage] = useState('');

  async function uploadCsv() {
    if (!file) return setMessage('Choose a CSV file first.');
    const formData = new FormData();
    formData.append('file', file);

    const res = await fetch('/api/upload-inventory', { method: 'POST', body: formData });
    const data = await res.json();
    setMessage(data.error || `Imported ${data.imported} parts. ${data.skipped || 0} rows skipped.`);
  }

  return (
    <main className="container">
      <div className="card">
        <h1>Upload aircraft parts inventory</h1>
        <p>Upload a CSV with the required columns. Seller accounts must have an active subscription.</p>
        <div className="notice">
          Required columns: part_number, cross_reference, description, quantity, condition, paperwork_status
        </div>
        <input className="input" type="file" accept=".csv" onChange={e => setFile(e.target.files?.[0] || null)} />
        <button className="button" onClick={uploadCsv}>Upload CSV</button>
        {message && <div className="notice">{message}</div>}
      </div>
    </main>
  );
}

import { NextResponse } from 'next/server';
import { stripe } from '@/lib/stripe';

const priceIds: Record<string, string | undefined> = {
  seller: process.env.NEXT_PUBLIC_STRIPE_SELLER_PRICE_ID,
  searcher: process.env.NEXT_PUBLIC_STRIPE_SEARCHER_PRICE_ID,
  credits20: process.env.NEXT_PUBLIC_STRIPE_CREDITS_20_PRICE_ID
};

export async function POST(req: Request) {
  try {
    const { type } = await req.json();
    const price = priceIds[type];
    if (!price) return NextResponse.json({ error: 'Missing Stripe price ID.' }, { status: 400 });

    const mode = type === 'credits20' ? 'payment' : 'subscription';
    const session = await stripe.checkout.sessions.create({
      mode,
      line_items: [{ price, quantity: 1 }],
      success_url: `${process.env.NEXT_PUBLIC_APP_URL}/account?checkout=success`,
      cancel_url: `${process.env.NEXT_PUBLIC_APP_URL}/pricing?checkout=cancelled`,
      metadata: { plan_type: type }
    });

    return NextResponse.json({ url: session.url });
  } catch (error: any) {
    return NextResponse.json({ error: error.message }, { status: 500 });
  }
}

import { NextResponse } from 'next/server';
import Papa from 'papaparse';
import { getAdminClient } from '@/lib/adminClient';

const allowedConditions = ['new', 'used', 'overhauled', 'serviceable', 'as_removed', 'repairable'];
const allowedPaperwork = ['available', 'not_available', 'unknown', 'easa_form_1', 'faa_8130_3', 'caa_form_1'];

function normalise(value: string) {
  return String(value || '').trim().toLowerCase().replaceAll(' ', '_').replaceAll('-', '_');
}

export async function POST(req: Request) {
  try {
    const supabase = getAdminClient();
    const authHeader = req.headers.get('authorization');

    // For a production app, pass the user's JWT from the browser and verify it here.
    // This scaffold keeps the import logic visible and ready to wire to Supabase Auth.
    if (!authHeader && process.env.NODE_ENV === 'production') {
      return NextResponse.json({ error: 'Not authenticated.' }, { status: 401 });
    }

    const form = await req.formData();
    const file = form.get('file') as File | null;
    if (!file) return NextResponse.json({ error: 'No file uploaded.' }, { status: 400 });

    const text = await file.text();
    const parsed = Papa.parse<Record<string, string>>(text, { header: true, skipEmptyLines: true });

    const rows = parsed.data;
    const parts = rows.map(row => ({
      seller_id: null,
      part_number: String(row.part_number || '').trim().toUpperCase(),
      cross_reference: String(row.cross_reference || '').trim().toUpperCase(),
      description: String(row.description || '').trim(),
      quantity: Number(row.quantity || 0),
      condition: normalise(row.condition),
      paperwork_status: normalise(row.paperwork_status),
      status: 'active'
    })).filter(part =>
      part.part_number &&
      Number.isFinite(part.quantity) &&
      part.quantity >= 0 &&
      allowedConditions.includes(part.condition) &&
      allowedPaperwork.includes(part.paperwork_status)
    );

    if (parts.length === 0) {
      return NextResponse.json({ error: 'No valid rows found. Check column names and allowed condition/paperwork values.' }, { status: 400 });
    }

    const { error } = await supabase.from('parts').insert(parts);
    if (error) return NextResponse.json({ error: error.message }, { status: 500 });

    return NextResponse.json({ imported: parts.length, skipped: rows.length - parts.length });
  } catch (error: any) {
    return NextResponse.json({ error: error.message }, { status: 500 });
  }
}

import { NextResponse } from 'next/server';
import { getAdminClient } from '@/lib/adminClient';

export async function POST(req: Request) {
  try {
    const { query, condition } = await req.json();
    const term = String(query || '').trim();
    if (!term) return NextResponse.json({ error: 'Enter a part number, cross-reference or description.' }, { status: 400 });

    const supabase = getAdminClient();

    // Production note: verify logged-in user, read profile, confirm active search subscription
    // or deduct one credit inside a database transaction before returning results.

    let dbQuery = supabase
      .from('parts')
      .select('id, part_number, cross_reference, description, quantity, condition, paperwork_status')
      .eq('status', 'active')
      .or(`part_number.ilike.%${term}%,cross_reference.ilike.%${term}%,description.ilike.%${term}%`)
      .limit(50);

    if (condition) dbQuery = dbQuery.eq('condition', condition);

    const { data, error } = await dbQuery;
    if (error) return NextResponse.json({ error: error.message }, { status: 500 });

    await supabase.from('search_logs').insert({ search_term: term, condition_filter: condition || null, result_count: data?.length || 0 });

    return NextResponse.json({ results: data || [] });
  } catch (error: any) {
    return NextResponse.json({ error: error.message }, { status: 500 });
  }
}

import { NextResponse } from 'next/server';
import { stripe } from '@/lib/stripe';
import { getAdminClient } from '@/lib/adminClient';

export async function POST(req: Request) {
  const body = await req.text();
  const signature = req.headers.get('stripe-signature');

  if (!signature) return NextResponse.json({ error: 'Missing Stripe signature.' }, { status: 400 });

  try {
    const event = stripe.webhooks.constructEvent(body, signature, process.env.STRIPE_WEBHOOK_SECRET!);
    const supabase = getAdminClient();

    if (event.type === 'checkout.session.completed') {
      const session: any = event.data.object;
      const planType = session.metadata?.plan_type;
      const customerEmail = session.customer_details?.email;

      if (customerEmail) {
        if (planType === 'credits20') {
          const { data: profile } = await supabase.from('profiles').select('*').eq('email', customerEmail).single();
          const currentCredits = Number(profile?.search_credits || 0);
          await supabase.from('profiles').upsert({ email: customerEmail, search_credits: currentCredits + 20 });
        } else {
          await supabase.from('profiles').upsert({
            email: customerEmail,
            subscription_status: 'active',
            stripe_customer_id: session.customer
          });
        }
      }
    }

    return NextResponse.json({ received: true });
  } catch (error: any) {
    return NextResponse.json({ error: error.message }, { status: 400 });
  }
}
